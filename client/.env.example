# Judge0 API Configuration
# Get your RapidAPI key from: https://rapidapi.com/judge0-official/api/judge0-ce

VITE_RAPIDAPI_KEY=your-rapidapi-key-here

# Backend API URL
VITE_API_URL=http://localhost:8000

# Firebase Configuration (Client-side)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Instructions:
# 1. Sign up at https://rapidapi.com/
# 2. Subscribe to Judge0 CE API (has a free tier)
# 3. Copy your API key
# 4. Create a .env file in the client directory
# 5. Add your actual keys (never commit .env to git!)
