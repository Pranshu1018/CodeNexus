# ==================================
# CLIENT ENVIRONMENT VARIABLES
# ==================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Backend API URL
# Development: http://localhost:8000
# Production: https://your-backend-domain.com
VITE_API_URL=http://localhost:8000

# Razorpay Public Key (Safe to expose in frontend)
# Get from: https://dashboard.razorpay.com/app/keys
# Test mode: rzp_test_XXXXXXXX
# Live mode: rzp_live_XXXXXXXX
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Judge0 API Configuration
# Get your RapidAPI key from: https://rapidapi.com/judge0-official/api/judge0-ce
VITE_RAPIDAPI_KEY=your-rapidapi-key-here

# Firebase Configuration (Client-side)
# Get from: Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# ==================================
# DEPLOYMENT NOTES
# ==================================
# For production deployment:
# 1. Update VITE_API_URL to your production backend URL
# 2. Use Razorpay LIVE keys (rzp_live_) instead of test keys
# 3. Ensure Firebase project is in production mode
# 4. Set these as environment variables in your hosting platform
#    (Vercel, Netlify, etc.)
