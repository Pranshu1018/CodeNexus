# ==================================
# SERVER ENVIRONMENT VARIABLES
# ==================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Server Configuration
PORT=8000
NODE_ENV=development

# JWT Secret for authentication (generate a random strong secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here-minimum-32-characters-long

# CORS Configuration (comma-separated allowed origins)
# Development: http://localhost:5173,http://localhost:3000
# Production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================================
# PAYMENT GATEWAY (Razorpay)
# ==================================
# Get from: https://dashboard.razorpay.com/app/keys
# IMPORTANT: Use TEST keys for development, LIVE keys for production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# ==================================
# AI/ML SERVICES
# ==================================
# Google Generative AI (Gemini) - For resume generation
# Get from: https://makersuite.google.com/app/apikey
GEN_AI_SECRET=your-google-ai-api-key-here

# Groq API - For chatbot
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ==================================
# WEB SCRAPING
# ==================================
# ZenRows API - For web scraping functionality
# Get from: https://www.zenrows.com/
ZENROWS_API_KEY=your-zenrows-api-key-here

# ==================================
# FIREBASE (Server-side)
# ==================================
# Get from: Firebase Console > Project Settings > Service Accounts
# For production, use Firebase Admin SDK with serviceAccountKey.json
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ==================================
# DEPLOYMENT CHECKLIST
# ==================================
# Before deploying to production:
# ✓ Set NODE_ENV=production
# ✓ Use strong JWT_SECRET (32+ characters)
# ✓ Update ALLOWED_ORIGINS to production frontend URL
# ✓ Use Razorpay LIVE keys (rzp_live_)
# ✓ Configure all API keys for production services
# ✓ Set up Firebase Admin SDK properly
# ✓ Enable HTTPS on your domain
# ✓ Set up proper error logging and monitoring
